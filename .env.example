# Equinox API — v1.0.1
APP_NAME=Equinox API
APP_VERSION=1.0.1
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/pokemon_teambuilder

# CORS
# Development can use *.
# Production must restrict this to your deployed frontend domain(s), comma-separated.
# Example: https://thihrq.github.io,https://equinox.app,https://www.equinox.app
CORS_ORIGIN=*

# Request body limit
JSON_LIMIT=1mb

# Smart Cache
EQUINOX_RECOMMENDATION_CACHE_TTL_MS=900000
EQUINOX_RECOMMENDATION_CACHE_MAX_ENTRIES=100

# Frontend reference
# The frontend uses frontend/.env.example.
# VITE_API_BASE_URL=http://localhost:3000
