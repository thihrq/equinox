# Equinox API — v1.0.2
APP_NAME=Equinox API
APP_VERSION=1.0.2
NODE_ENV=development
PORT=3000
MONGO_URI=mongodb://localhost:27017/pokemon_teambuilder

# CORS
# Development can use *.
# Production must use the exact GitHub Pages origin, without path.
# Browser Origin does not include /repository-name.
# Example for GitHub Pages:
# CORS_ORIGIN=https://thiihrq.github.io
CORS_ORIGIN=*

# Optional aliases accepted by the API config:
# CORS_ORIGINS=https://thiihrq.github.io,https://equinox.app
# FRONTEND_URL=https://thiihrq.github.io
# CORS_ORIGIN_PATTERNS=^https:\/\/.*\.github\.io$

# Runtime profile
# standard = local/stronger servers
# render_free = lower search budgets to avoid Render Free 502/timeouts
EQUINOX_RUNTIME_PROFILE=standard

# Request body limit
JSON_LIMIT=1mb

# Smart Cache
EQUINOX_RECOMMENDATION_CACHE_TTL_MS=900000
EQUINOX_RECOMMENDATION_CACHE_MAX_ENTRIES=100

# Frontend reference
# The frontend uses frontend/.env.example.
# VITE_API_BASE_URL=http://localhost:3000
