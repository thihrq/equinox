{
  "name": "pokemon-builder",
  "version": "1.0.3",
  "description": "Equinox v1.0.3 competitive and scenario-aware PokÃƒÂ©mon team builder API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/server.js",
    "prod:check": "npm run preflight && npm --prefix frontend run build",
    "data:check": "ts-node src/scripts/validateDataPacks.ts",
    "data:audit": "ts-node src/scripts/validateCompetitiveSetDataAudit.ts",
    "data-mode:test": "ts-node src/config/dataMode.test.ts",
    "data:snapshot": "ts-node src/scripts/snapshotCompetitiveData.ts",
    "sets:structure:check": "ts-node src/scripts/validateCompetitiveData.ts",
    "sets:legality:check": "ts-node src/scripts/validateCompetitiveLegality.ts",
    "sets:coherence:check": "ts-node src/scripts/validateCompetitiveCoherence.ts",
    "sets:coverage:check": "ts-node src/scripts/validateCompetitiveCoverage.ts",
    "sets:offline-guards:check": "ts-node src/scripts/validateOfflineAuditGuards.ts",
    "sets:import": "ts-node src/scripts/importCompetitiveSets.ts",
    "sets:import:dry": "ts-node src/scripts/importCompetitiveSets.ts --file src/equinox/data-packs/competitive/champions-reg-mb-doubles/sets.json --regulation champions_reg_m_b_doubles --source equinox-curated-champions-mb-doubles --dry-run",
    "sets:migrate:v2": "ts-node src/scripts/migratePokemonSetsV2.ts",
    "sets:migrate:dry": "ts-node src/scripts/migratePokemonSetsV2.ts --dry-run",
    "sets:publish:staging": "ts-node src/scripts/publishCompetitiveSetsStaging.ts",
    "sets:publish:staging:dry": "ts-node src/scripts/publishCompetitiveSetsStaging.ts --dry-run",
    "sets:shadow:compare": "ts-node src/scripts/compareCompetitiveSetsShadow.ts",
    "sets:shadow:homologate": "ts-node src/scripts/validateShadowHomologation.ts",
    "sets:staging:homologate": "ts-node src/scripts/validateStagingHomologation.ts",
    "sets:staging:homologate:fixture": "ts-node src/scripts/validateStagingHomologation.ts --fixture",
    "sets:v2-shadow-selection:check": "ts-node src/scripts/validateV2TeamBuilderShadow.ts",
    "sets:verified:readiness": "ts-node src/scripts/validateVerifiedReadiness.ts",
    "sets:promote:verified": "ts-node src/scripts/promoteReviewedSetsToVerified.ts",
    "sets:promote:verified:dry": "ts-node src/scripts/promoteReviewedSetsToVerified.ts --dry-run",
    "sets:verified:matchups": "ts-node src/scripts/validateVerifiedMatchupEvidence.ts",
    "sets:rollback:verified:staging": "ts-node src/scripts/rollbackVerifiedStagingPromotion.ts",
    "sets:rollback:verified:staging:dry": "ts-node src/scripts/rollbackVerifiedStagingPromotion.ts --dry-run",
    "sets:verified:staging:check": "ts-node src/scripts/validateVerifiedStagingPromotion.ts",
    "mongo:snapshot": "ts-node src/scripts/snapshotMongoCompetitiveData.ts",
    "recommendation:check": "ts-node src/scripts/validateRecommendationRules.ts",
    "balance:check": "ts-node src/scripts/validateBalanceEngine.ts",
    "synergy:check": "ts-node src/scripts/validateSynergyEngine.ts",
    "lead:pipeline:check": "ts-node src/scripts/validateLeadBuildPipeline.ts",
    "regression:check": "ts-node src/scripts/validateLegacyRegression.ts",
    "release:check": "npm run preflight && npm --prefix frontend run build",
    "format:check": "ts-node src/scripts/auditFormatScope.ts",
    "preflight": "npm run typecheck && npm run data-mode:test && npm run sets:offline-guards:check && npm run data:check && npm run data:audit && npm run sets:structure:check && npm run sets:legality:check && npm run sets:coherence:check && npm run sets:coverage:check && npm run sets:import:dry && npm run sets:migrate:dry && npm run sets:publish:staging:dry && npm run sets:shadow:compare && npm run sets:shadow:homologate && npm run sets:staging:homologate:fixture && npm run sets:v2-shadow-selection:check && npm run sets:verified:readiness && npm run format:check && npm run synergy:check && npm run recommendation:check && npm run balance:check && npm run vgc:playbook:check && npm run lead:pipeline:check && npm run regression:check",
    "release:build": "npm run build && npm --prefix frontend run build",
    "db:seed": "ts-node src/workers/runWorker.ts",
    "db:seed:compiled": "node dist/workers/runWorker.js",
    "vgc:playbook:check": "ts-node src/scripts/validateVgcPlaybook.ts",
    "sets:activate:staging": "ts-node src/scripts/promoteVerifiedSetsToActive.ts",
    "sets:activate:staging:dry": "ts-node src/scripts/promoteVerifiedSetsToActive.ts --dry-run",
    "sets:activate:staging:check": "ts-node src/scripts/validateActiveStagingPromotion.ts",
    "sets:activate:staging:rollback": "ts-node src/scripts/rollbackActiveStagingPromotion.ts",
    "sets:active-staging:contracts:check": "ts-node src/scripts/validateActiveStagingHomologationContracts.ts",
    "sets:active-staging:config:check": "ts-node src/scripts/validateActiveStagingHomologationConfig.ts",
    "sets:active-staging:monitoring:check": "ts-node src/scripts/validateActiveStagingHomologationMonitoring.ts",
    "sets:active-staging:repository:check": "ts-node src/scripts/validateActiveStagingRepository.ts",
    "sets:active-staging:repository:exit-codes:check": "ts-node src/scripts/validateActiveStagingRepositoryExitCodes.ts",
    "sets:active-staging:engine-adapter:check": "ts-node src/scripts/validateActiveStagingEngineAdapter.ts"
  },
  "keywords": [
    "pokemon",
    "team-builder",
    "equinox"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@pkmn/dex": "^0.10.11",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
